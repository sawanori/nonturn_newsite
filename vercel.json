{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["hnd1", "sfo1"],
  "redirects": [
    {
      "source": "/services/photo/foodphoto",
      "has": [{ "type": "host", "value": "non-turn.com" }],
      "destination": "https://foodphoto-pro.com/",
      "permanent": true
    },
    {
      "source": "/services/photo/foodphoto/:path*",
      "has": [{ "type": "host", "value": "non-turn.com" }],
      "destination": "https://foodphoto-pro.com/:path*",
      "permanent": true
    }
  ]
}